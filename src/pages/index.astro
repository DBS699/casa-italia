---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Committee from '../components/Committee.astro';
import Season from '../components/Season.astro';
import Membership from '../components/Membership.astro';
import Gallery from '../components/Gallery.astro';
import Sponsors from '../components/Sponsors.astro';
import Footer from '../components/Footer.astro';
import JoinDialog from '../components/JoinDialog.astro';
import NextRide from '../components/NextRide.astro';
---

<Base>
  <Header />
  <main>
    {/* Flow: Hero → Verein → Nächste Ausfahrt → Touren → Galerie → Mitmachen → Komitee → Sponsoren → Footer.
        Erst der Verein + das Fahren (was Besucher anzieht), dann die Conversion, danach Vertrauen (Komitee/Sponsoren). */}
    <Hero />
    <About />
    <NextRide />
    <Season />
    <Gallery />
    <Membership />
    <Committee />
    <Sponsors />
  </main>
  <Footer />
  <JoinDialog />
</Base>
