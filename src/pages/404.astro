---
import Base from '../layouts/Base.astro';
---

<Base title="Seite nicht gefunden — Velo-Club Casa d'Italia" description="Diese Seite existiert nicht.">
  <main class="notfound">
    <a href="/" aria-label="Zur Startseite"><img class="nf-emblem" src="/assets/logo.png" alt="Velo Club Casa d'Italia" /></a>
    <div class="nf-code">Fehler 404</div>
    <h1 class="nf-title">Hier geht's nicht weiter.</h1>
    <p class="nf-text">Diese Seite gibt es nicht (mehr) – wie eine Ausfahrt ohne Karte. Zurück aufs Rad und ab zur Startseite.</p>
    <a class="btn btn-green" href="/">Zur Startseite</a>
  </main>

  <style>
    .notfound {
      min-height: 82vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      padding: clamp(40px, 8vw, 90px) 24px; background: var(--paper);
    }
    .nf-emblem { width: 76px; height: 76px; object-fit: contain; margin-bottom: 24px; }
    .nf-code {
      font-family: var(--label); text-transform: uppercase; letter-spacing: 0.22em;
      font-size: 13px; font-weight: 600; color: var(--green); margin-bottom: 10px;
    }
    .nf-title {
      font-family: var(--serif); font-weight: 400; font-style: italic;
      font-size: clamp(30px, 5vw, 50px); line-height: 1.05; margin: 0 0 16px; color: var(--ink);
    }
    .nf-text {
      font-size: 18px; line-height: 1.7; color: var(--ink-soft);
      max-width: 460px; margin: 0 0 30px; text-wrap: pretty;
    }
  </style>
</Base>
