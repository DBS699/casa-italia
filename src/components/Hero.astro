---
import { I18N, DEFAULT_LANG, CLUB, SITE } from '../data/content.js';
const t = I18N[DEFAULT_LANG];
---

<section id="hero" class="hero" aria-label="Intro">
  <!--
    Background video. The poster shows instantly; the video is then loaded and
    autoplayed (muted) — on desktop AND mobile. We only skip the fetch when the
    visitor has data-saver on, is on a very slow (2G) connection, or asked to
    reduce motion — those get the poster only. Replace /public/assets/hero.mp4
    (+ hero-poster.jpg) with the real club video anytime — filenames are fixed.
  -->
  <video class="hero-video" autoplay muted loop playsinline preload="none" poster={SITE.heroPoster} data-src={SITE.heroVideo}></video>
  <script is:inline>
    (function () {
      var v = document.querySelector('.hero-video');
      if (!v || !v.dataset.src) return;
      var motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      var conn = navigator.connection || {};
      var thrifty = conn.saveData === true || /(^|-)2g$/.test(conn.effectiveType || '');
      if (motionOk && !thrifty) {
        var s = document.createElement('source');
        s.src = v.dataset.src; s.type = 'video/mp4';
        v.appendChild(s); v.load();
        var p = v.play(); if (p && p.catch) p.catch(function () {});
      }
    })();
  </script>
  <div class="scrim"></div>
  <div class="inner">
    <img class="laurel" src="/assets/laurel-cut.png" alt="Velo Club Casa d'Italia – seit 1985" />
    <h1>{SITE.heroMotto}</h1>
    <p class="hero-sub" data-i18n="heroSub">{t.heroSub}</p>
    <p class="hero-intro" data-i18n="heroIntro">{t.heroIntro}</p>
    <div class="actions">
      <button type="button" class="btn btn-green" data-join data-i18n="ctaJoin">{t.ctaJoin}</button>
      <a class="btn btn-ghost-light" href="#touren" data-i18n="ctaSeason">{t.ctaSeason}</a>
    </div>
  </div>
</section>
