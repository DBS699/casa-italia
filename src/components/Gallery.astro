---
import { I18N, DEFAULT_LANG, GALLERY } from '../data/content.js';
const t = I18N[DEFAULT_LANG];
---

<section id="gallery" class="section white bordered reveal gallery" aria-label="Galerie">
  <div class="container">
    <div class="season-head">
      <div>
        <div class="kicker">
          <span class="swatch"><span style="background:#1f7a43"></span><span style="background:#fff"></span><span style="background:#c0202a"></span></span>
          <span data-i18n="galleryKicker">{t.galleryKicker}</span>
        </div>
        <h2 data-i18n="galleryTitle">{t.galleryTitle}</h2>
        <p class="lead" data-i18n="galleryBody">{t.galleryBody}</p>
      </div>
      <div class="season-arrows" aria-hidden="true">
        <button type="button" class="season-arrow" data-dir="-1" aria-label="Vorherige Bilder">‹</button>
        <button type="button" class="season-arrow" data-dir="1" aria-label="Weitere Bilder">›</button>
      </div>
    </div>

    <div class="tour-track gallery-track" role="list" tabindex="0" aria-label="Galerie">
      {GALLERY.map((s, i) => (
        <div class="gallery-slide" role="listitem">
          <button type="button" class="gallery-open" data-index={i} aria-label="Bild vergrössern">
            <img id={s.id} src={s.image} alt={s.caption} data-caption={s.caption} width="380" height="254" loading="lazy" decoding="async" />
          </button>
          {s.caption && <span class="gallery-cap">{s.caption}</span>}
        </div>
      ))}
    </div>
  </div>

  <!-- Lightbox (click an image → full-screen viewer, zooms in) -->
  <dialog class="lightbox" aria-label="Galerie-Bild">
    <button type="button" class="lb-close" aria-label="Schliessen">×</button>
    <button type="button" class="lb-nav lb-prev" aria-label="Vorheriges Bild">‹</button>
    <figure class="lb-figure">
      <img class="lb-img" alt="" />
      <figcaption class="lb-cap" hidden></figcaption>
    </figure>
    <button type="button" class="lb-nav lb-next" aria-label="Nächstes Bild">›</button>
    <div class="lb-counter" aria-hidden="true"><span class="lb-cur">1</span> / <span class="lb-total">1</span></div>
  </dialog>
</section>

<script is:inline>
  (function () {
    const track = document.querySelector('#gallery .gallery-track');
    if (!track) return;
    const arrows = document.querySelectorAll('#gallery .season-arrow');
    const step = () => { const c = track.querySelector('.gallery-slide'); return c ? c.getBoundingClientRect().width + 24 : 360; };
    arrows.forEach((b) => b.addEventListener('click', () =>
      track.scrollBy({ left: step() * Number(b.dataset.dir), behavior: 'smooth' })));
    const upd = () => {
      const max = track.scrollWidth - track.clientWidth - 2;
      arrows.forEach((b) => {
        const edge = Number(b.dataset.dir) < 0 ? track.scrollLeft <= 2 : track.scrollLeft >= max;
        b.classList.toggle('is-disabled', edge || max <= 0);
      });
    };
    track.addEventListener('scroll', upd, { passive: true });
    window.addEventListener('resize', upd);
    upd();

    // ── lightbox ──────────────────────────────────────────
    const lb = document.querySelector('#gallery .lightbox');
    const slides = [...track.querySelectorAll('.gallery-slide img')].map((i) => ({ src: i.currentSrc || i.src, cap: i.getAttribute('data-caption') || '' }));
    if (lb && slides.length) {
      const lbImg = lb.querySelector('.lb-img');
      const lbCap = lb.querySelector('.lb-cap');
      const cur = lb.querySelector('.lb-cur');
      lb.querySelector('.lb-total').textContent = slides.length;
      const multi = slides.length > 1;
      lb.querySelectorAll('.lb-nav').forEach((b) => { b.hidden = !multi; });
      let idx = 0;
      const show = (n) => {
        idx = (n + slides.length) % slides.length;
        lbImg.src = slides[idx].src;
        cur.textContent = idx + 1;
        lbCap.textContent = slides[idx].cap;
        lbCap.hidden = !slides[idx].cap;
      };
      document.querySelectorAll('#gallery .gallery-open').forEach((btn) => {
        btn.addEventListener('click', () => { show(Number(btn.dataset.index)); lb.showModal(); });
      });
      lb.querySelector('.lb-prev').addEventListener('click', () => show(idx - 1));
      lb.querySelector('.lb-next').addEventListener('click', () => show(idx + 1));
      lb.querySelector('.lb-close').addEventListener('click', () => lb.close());
      lb.addEventListener('keydown', (e) => {
        if (!multi) return;
        if (e.key === 'ArrowRight') { e.preventDefault(); show(idx + 1); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); show(idx - 1); }
      });
      // click on the dark surround (the dialog box itself) closes
      lb.addEventListener('click', (e) => { if (e.target === lb) lb.close(); });
    }
  })();
</script>
