---
import { I18N, DEFAULT_LANG, TOURS, SITE } from '../data/content.js';
const t = I18N[DEFAULT_LANG];

// Split "04. Mai" → day "04", month "Mai" for the calendar-style date badge.
const tours = TOURS.map((tour) => {
  const m = String(tour.date).match(/^\s*(\d{1,2})\.?\s+(.+)$/);
  return { ...tour, day: m ? m[1] : '', monthLabel: m ? m[2] : tour.date };
});
---

<section id="touren" class="section white bordered reveal season" aria-label="Touren / Saison">
  <div class="container">
    <div class="season-head">
      <div>
        <div class="kicker">
          <span class="swatch"><span style="background:#1f7a43"></span><span style="background:#fff"></span><span style="background:#c0202a"></span></span>
          <span data-i18n="seasonKicker">{t.seasonKicker}</span>
        </div>
        <h2 data-i18n="seasonTitle">{t.seasonTitle}</h2>
        <p class="lead" data-i18n="seasonBody">{t.seasonBody}</p>
        {SITE.brochure && (
          <div class="season-doc">
            <a class="btn btn-green" href={SITE.brochure} target="_blank" rel="noopener" data-i18n="member.programmView">{t.member.programmView}</a>
            <a class="btn btn-ghost-dark" href={SITE.brochure} download data-i18n="member.download">{t.member.download}</a>
          </div>
        )}
      </div>
      <div class="season-arrows" aria-hidden="true">
        <button type="button" class="season-arrow" data-dir="-1" aria-label="Vorherige Touren">‹</button>
        <button type="button" class="season-arrow" data-dir="1" aria-label="Weitere Touren">›</button>
      </div>
    </div>

    <div class="tour-track" role="list" tabindex="0" aria-label="Touren der Saison">
      {tours.map((tour) => (
        <button
          type="button"
          class="tour-card"
          role="listitem"
          data-title={tour.title}
          data-day={tour.day}
          data-month={tour.monthLabel}
          data-img={tour.img}
          data-desc={tour.description ?? ''}
          data-meet={tour.meet ?? ''}
          data-g1name={tour.g1name ?? ''}
          data-g1route={tour.g1route ?? ''}
          data-distance={tour.distance ?? ''}
          data-elev={tour.elevation ?? ''}
          data-g2name={tour.g2name ?? ''}
          data-g2route={tour.g2route ?? ''}
          data-g2dist={tour.g2distance ?? ''}
          data-g2elev={tour.g2elevation ?? ''}
          data-url={tour.url ?? ''}
          data-gpx={tour.gpx ?? ''}
          data-g2url={tour.g2url ?? ''}
          data-g2gpx={tour.g2gpx ?? ''}
        >
          <div class="tour-photo">
            <img src={tour.img} alt={tour.title} width="800" height="520" loading="lazy" decoding="async" />
            <span class="tour-badge"><span class="d">{tour.day}</span><span class="m">{tour.monthLabel}</span></span>
          </div>
          <div class="tour-meta">
            <h3 class="tour-title">{tour.title}</h3>
            <span class="tour-more">Details <span class="arrow">→</span></span>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Tour detail dialog (filled on click, zooms in) -->
  <dialog class="tour-modal" aria-labelledby="tm-title">
    <button class="tm-close" type="button" aria-label="Schliessen">×</button>
    <div class="tm-photo">
      <img alt="" />
      <span class="tour-badge"><span class="d"></span><span class="m"></span></span>
    </div>
    <div class="modal-body">
      <h3 id="tm-title" class="tm-title"></h3>
      <p class="tm-desc"></p>
      <div class="tm-tabs" role="tablist" hidden>
        <button type="button" class="tm-tab" data-g="0"></button>
        <button type="button" class="tm-tab" data-g="1"></button>
      </div>
      <div class="tm-panel" hidden>
        <span class="tm-panel-name"></span>
        <span class="tm-panel-facts"></span>
        <div class="tm-panel-route"></div>
        <div class="tm-map" hidden></div>
        <div class="tm-actions">
          <a class="btn btn-green tm-route" target="_blank" rel="noopener" hidden><span class="tm-route-label">Route ansehen</span> <span class="arrow" style="font-size:16px">→</span></a>
          <a class="btn btn-ghost-dark tm-gpx" download hidden>GPX herunterladen</a>
        </div>
      </div>
      <div class="tm-meet"><span class="k">Treffpunkt</span><span class="tm-meet-val"></span></div>
    </div>
  </dialog>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector('#touren');
    if (!root) return;
    const track = root.querySelector('.tour-track');
    const dlg = root.querySelector('.tour-modal');

    // ── carousel arrows ───────────────────────────────────
    const step = () => {
      const card = track.querySelector('.tour-card');
      return card ? card.getBoundingClientRect().width + 24 : 320;
    };
    const arrows = root.querySelectorAll('.season-arrow');
    arrows.forEach((btn) => btn.addEventListener('click', () =>
      track.scrollBy({ left: step() * Number(btn.dataset.dir), behavior: 'smooth' })));
    const updateArrows = () => {
      const max = track.scrollWidth - track.clientWidth - 2;
      arrows.forEach((b) => {
        const atEdge = Number(b.dataset.dir) < 0 ? track.scrollLeft <= 2 : track.scrollLeft >= max;
        b.classList.toggle('is-disabled', atEdge || max <= 0);
      });
    };
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    updateArrows();

    // ── detail dialog ─────────────────────────────────────
    const set = (sel, val) => { const el = dlg.querySelector(sel); if (el) el.textContent = val || ''; };

    // Strava route/activity embed (interactive map) — auto-detected from a pasted strava.com link.
    const stravaEmbed = (url) => {
      try {
        const u = new URL(url);
        if (!/(^|\.)strava\.com$/i.test(u.hostname)) return null;
        const parts = u.pathname.split('/').filter(Boolean);
        const type = parts.includes('activities') ? 'activity' : parts.includes('routes') ? 'route' : null;
        if (!type) return null;
        const id = parts.reverse().find((p) => /^\d+$/.test(p)); // last all-digits segment = id
        return id ? { type, id } : null;
      } catch (e) { return null; }
    };
    const map = dlg.querySelector('.tm-map');
    const showStravaMap = (emb) => {
      map.innerHTML = '';
      if (!emb) { map.hidden = true; return; }
      const ph = document.createElement('div');
      ph.className = 'strava-embed-placeholder';
      ph.setAttribute('data-embed-type', emb.type);
      ph.setAttribute('data-embed-id', emb.id);
      ph.setAttribute('data-style', 'standard');
      ph.setAttribute('data-slippy', 'true');
      map.appendChild(ph);
      map.hidden = false;
      // (re)load Strava's embed script so it converts the just-added placeholder
      const old = document.getElementById('strava-embed-js');
      if (old) old.remove();
      const s = document.createElement('script');
      s.id = 'strava-embed-js';
      s.src = 'https://strava-embeds.com/embed.js';
      document.body.appendChild(s);
    };
    // ── group tabs (Grappa / Gemeinsame Ausfahrt) inside the modal ──
    const tabsWrap = dlg.querySelector('.tm-tabs');
    const tabs = [...dlg.querySelectorAll('.tm-tab')];
    const panel = dlg.querySelector('.tm-panel');
    const panelName = dlg.querySelector('.tm-panel-name');
    const panelFacts = dlg.querySelector('.tm-panel-facts');
    const panelRoute = dlg.querySelector('.tm-panel-route');
    const routeBtn = dlg.querySelector('.tm-route');
    const gpxBtn = dlg.querySelector('.tm-gpx');
    let groups = [];
    const selectTab = (idx) => {
      const g = groups[idx];
      if (!g) return;
      tabs.forEach((t, i) => t.classList.toggle('is-active', i === idx));
      panelName.textContent = g.name || '';
      panelName.hidden = groups.length > 1 || !g.name; // the active tab already shows the name when there are two
      panelFacts.textContent = g.facts || '';
      panelRoute.textContent = g.route || ''; panelRoute.hidden = !g.route;
      if (g.url) {
        routeBtn.href = g.url; routeBtn.hidden = false;
        const host = (() => { try { return new URL(g.url).hostname; } catch (e) { return ''; } })();
        routeBtn.querySelector('.tm-route-label').textContent =
          /garmin\.com$/i.test(host) ? 'In Garmin Connect öffnen'
          : /strava\.com$/i.test(host) ? 'Auf Strava ansehen'
          : 'Route ansehen';
      } else { routeBtn.hidden = true; }
      if (g.gpx) { gpxBtn.href = g.gpx; gpxBtn.hidden = false; } else { gpxBtn.hidden = true; }
      showStravaMap(stravaEmbed(g.url));
    };
    tabs.forEach((tab, i) => tab.addEventListener('click', () => selectTab(i)));

    root.querySelectorAll('.tour-card').forEach((card) => {
      card.addEventListener('click', () => {
        const d = card.dataset;
        const img = dlg.querySelector('.tm-photo img');
        img.src = d.img; img.alt = d.title;
        set('.tm-photo .tour-badge .d', d.day);
        set('.tm-photo .tour-badge .m', d.month);
        set('.tm-title', d.title);
        set('.tm-desc', d.desc);
        // build the group list — each group becomes a tab with its own facts/route/map/links
        groups = [];
        if (d.g1name || d.distance || d.g1route) groups.push({ name: d.g1name, facts: [d.distance, d.elev].filter(Boolean).join(' · '), route: d.g1route, url: d.url, gpx: d.gpx });
        if (d.g2name || d.g2dist || d.g2route) groups.push({ name: d.g2name, facts: [d.g2dist, d.g2elev].filter(Boolean).join(' · '), route: d.g2route, url: d.g2url, gpx: d.g2gpx });
        tabsWrap.hidden = groups.length < 2;
        tabs.forEach((tab, i) => {
          if (groups[i]) { tab.textContent = groups[i].name || ('Gruppe ' + (i + 1)); tab.hidden = false; }
          else tab.hidden = true;
        });
        panel.hidden = groups.length === 0;
        if (groups.length) selectTab(0); else showStravaMap(null);
        set('.tm-meet-val', d.meet);
        dlg.showModal();
      });
    });
    // stop the embedded map (and reset) whenever the dialog closes
    dlg.addEventListener('close', () => { map.innerHTML = ''; map.hidden = true; });
    dlg.querySelector('.tm-close').addEventListener('click', () => dlg.close());
    // click on the backdrop (outside the dialog box) closes
    dlg.addEventListener('click', (e) => {
      const r = dlg.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) dlg.close();
    });
  })();
</script>
