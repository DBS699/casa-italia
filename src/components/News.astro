---
import { I18N, DEFAULT_LANG, NEWS_LINKS } from '../data/content.js';
const t = I18N[DEFAULT_LANG];
---

<section id="aktuelles" class="section paper reveal news" aria-label="Aktuelles">
  <div class="container">
    <div class="kicker">
      <span class="swatch"><span style="background:#1f7a43"></span><span style="background:#f6f2e9"></span><span style="background:#c0202a"></span></span>
      <span data-i18n="newsKicker">{t.newsKicker}</span>
    </div>
    <h2 data-i18n="newsTitle">{t.newsTitle}</h2>
    <div class="news-grid">
      {t.cards.map((c, i) => {
        const isJoin = c.n === '01';
        const Tag = isJoin ? 'button' : 'a';
        return (
          <Tag
            class="news-card"
            type={isJoin ? 'button' : undefined}
            href={isJoin ? undefined : NEWS_LINKS[c.n]}
            data-join={isJoin || undefined}
          >
            <span class="top-bar"><span class="g"></span><span class="w"></span><span class="r"></span></span>
            <span class="num" data-i18n={`cards.${i}.n`}>{c.n}</span>
            <h3 data-i18n={`cards.${i}.title`}>{c.title}</h3>
            <p data-i18n={`cards.${i}.body`}>{c.body}</p>
            <span class="cta"><span data-i18n={`cards.${i}.cta`}>{c.cta}</span> <span class="arrow">→</span></span>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
